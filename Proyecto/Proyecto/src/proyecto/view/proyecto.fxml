<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="15"
      prefHeight="400.0"
      prefWidth="400.0"
      style="-fx-background-color: #1E1E1E;"
      xmlns="http://javafx.com/javafx/23.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="proyecto.controller.Controller">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- Título -->
    <Label text="Conversor de Bases"
           style="
               -fx-font-size: 24px;
               -fx-font-weight: bold;
               -fx-text-fill: white;
           "/>

    <!-- Formulario -->
    <GridPane alignment="CENTER"
              hgap="10"
              vgap="15">

        <!-- Número -->
        <Label text="Número:"
               style="-fx-text-fill: white;"
               GridPane.rowIndex="0"
               GridPane.columnIndex="0"/>

        <TextField fx:id="txtNumero"
                   promptText="Ingrese un número"
                   prefWidth="200"
                   GridPane.rowIndex="0"
                   GridPane.columnIndex="1"/>

        <!-- Base origen -->
        <Label text="Base origen:"
               style="-fx-text-fill: white;"
               GridPane.rowIndex="1"
               GridPane.columnIndex="0"/>

        <ComboBox fx:id="cbOrigen"
                  prefWidth="200"
                  GridPane.rowIndex="1"
                  GridPane.columnIndex="1"/>

        <!-- Base destino -->
        <Label text="Base destino:"
               style="-fx-text-fill: white;"
               GridPane.rowIndex="2"
               GridPane.columnIndex="0"/>

        <ComboBox fx:id="cbDestino"
                  prefWidth="200"
                  GridPane.rowIndex="2"
                  GridPane.columnIndex="1"/>

    </GridPane>

    <!-- Botón -->
    <Button text="Convertir"
            onAction="#convertir"
            prefWidth="150"
            style="
                -fx-background-color: #3B82F6;
                -fx-text-fill: white;
                -fx-font-size: 14px;
                -fx-font-weight: bold;
                -fx-background-radius: 8px;
                -fx-cursor: hand;
            "/>

    <!-- Resultado -->
    <VBox alignment="CENTER" spacing="5">

        <Label text="Resultado:"
               style="
                   -fx-text-fill: white;
                   -fx-font-size: 16px;
               "/>

        <Label fx:id="lblResultado"
               text="---"
               style="
                   -fx-text-fill: #22C55E;
                   -fx-font-size: 28px;
                   -fx-font-weight: bold;
               "/>

    </VBox>

</VBox>
